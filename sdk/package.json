{
  "name": "@bridge-watch/contract-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for BridgeWatch Soroban contract integrations",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "stellar",
    "soroban",
    "bridge",
    "sdk"
  ],
  "author": "Bridge Watch",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^14.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
