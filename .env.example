# =============================================================================
# Bridge Watch — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
WS_PORT=3002

# -----------------------------------------------------------------------------
# PostgreSQL + TimescaleDB
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bridge_watch
POSTGRES_USER=bridge_watch
POSTGRES_PASSWORD=bridge_watch_dev

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL_SEC=300

# -----------------------------------------------------------------------------
# Stellar Network
# -----------------------------------------------------------------------------
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_MAINNET_RPC_URL=https://soroban-rpc.stellar.org
HORIZON_TIMEOUT_MS=30000

# Soroban contract IDs
CIRCUIT_BREAKER_CONTRACT_ID=
LIQUIDITY_CONTRACT_ADDRESS=

# -----------------------------------------------------------------------------
# Ethereum / EVM Chains
# -----------------------------------------------------------------------------
RPC_PROVIDER_TYPE=http

# Ethereum Mainnet
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_RPC_WS_URL=wss://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_RPC_FALLBACK_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC_FALLBACK_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Base
BASE_RPC_URL=https://mainnet.base.org
BASE_RPC_FALLBACK_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# -----------------------------------------------------------------------------
# Bridge & Token Addresses (Ethereum Mainnet)
# -----------------------------------------------------------------------------
USDC_TOKEN_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDC_BRIDGE_ADDRESS=0x55fe002a30Ad2d2D0cf70001042185dE33543204
EURC_TOKEN_ADDRESS=0x1aBaEA1f7df457398a0d4E980050846c85198C54
EURC_BRIDGE_ADDRESS=0xC138b627702652A0665D73D219f8090240596959

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
# Circle API
CIRCLE_API_KEY=
CIRCLE_API_URL=https://api.circle.com/v1
CIRCLE_API_TIMEOUT_MS=10000
CIRCLE_CACHE_TTL_SEC=60
CIRCLE_RATE_LIMIT_MAX=100
CIRCLE_RATE_LIMIT_WINDOW_MS=60000

# Coinbase Advanced Trade API
COINBASE_API_KEY=
COINBASE_API_SECRET=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_BURST_MULTIPLIER=2
# Comma-separated IPs to bypass rate limiting
RATE_LIMIT_WHITELIST_IPS=
# Comma-separated API keys to bypass rate limiting
RATE_LIMIT_WHITELIST_KEYS=

# -----------------------------------------------------------------------------
# Monitoring Thresholds
# -----------------------------------------------------------------------------
PRICE_DEVIATION_THRESHOLD=0.02
BRIDGE_SUPPLY_MISMATCH_THRESHOLD=0.1

# -----------------------------------------------------------------------------
# Background Jobs & Retries
# -----------------------------------------------------------------------------
RETRY_MAX=3
BRIDGE_VERIFICATION_INTERVAL_MS=300000

# -----------------------------------------------------------------------------
# Health Score Weights (must sum to 1.0)
# -----------------------------------------------------------------------------
HEALTH_WEIGHT_LIQUIDITY=0.25
HEALTH_WEIGHT_PRICE=0.25
HEALTH_WEIGHT_BRIDGE=0.20
HEALTH_WEIGHT_RESERVES=0.20
HEALTH_WEIGHT_VOLUME=0.10

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Docker Dev Tools (used by docker-compose.dev.yml only)
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173
PGADMIN_EMAIL=admin@bridgewatch.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin
REDIS_COMMANDER_PORT=8081
