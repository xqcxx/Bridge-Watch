{
  "dashboard": {
    "title": "Stellar Bridge Watch - Application Overview",
    "tags": ["stellar", "bridge", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate",
        "type": "graph",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{route}} - {{status_code}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "reqps", "label": "Requests/sec" },
          { "format": "short" }
        ]
      },
      {
        "id": 2,
        "title": "HTTP Request Duration (p95)",
        "type": "graph",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{method}} {{route}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "s", "label": "Duration" },
          { "format": "short" }
        ]
      },
      {
        "id": 3,
        "title": "Active HTTP Connections",
        "type": "graph",
        "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "http_active_connections",
            "legendFormat": "Active Connections",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Database Query Duration (p95)",
        "type": "graph",
        "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(db_query_duration_seconds_bucket[5m]))",
            "legendFormat": "{{operation}} on {{table}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "s", "label": "Duration" },
          { "format": "short" }
        ]
      },
      {
        "id": 5,
        "title": "Database Connections",
        "type": "graph",
        "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "db_connections_active",
            "legendFormat": "Active",
            "refId": "A"
          },
          {
            "expr": "db_connections_idle",
            "legendFormat": "Idle",
            "refId": "B"
          }
        ]
      },
      {
        "id": 6,
        "title": "Bridge Verification Success Rate",
        "type": "graph",
        "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(bridge_verification_success_total[5m]) / rate(bridge_verifications_total[5m]) * 100",
            "legendFormat": "{{bridge_name}} - {{asset}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "percent", "label": "Success Rate", "max": 100, "min": 0 },
          { "format": "short" }
        ]
      },
      {
        "id": 7,
        "title": "Bridge Health Scores",
        "type": "graph",
        "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "bridge_health_score",
            "legendFormat": "{{bridge_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "short", "label": "Health Score", "max": 100, "min": 0 },
          { "format": "short" }
        ]
      },
      {
        "id": 8,
        "title": "Queue Jobs Status",
        "type": "graph",
        "gridPos": { "x": 0, "y": 22, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "queue_jobs_active",
            "legendFormat": "Active - {{job_type}}",
            "refId": "A"
          },
          {
            "expr": "queue_jobs_waiting",
            "legendFormat": "Waiting - {{job_type}}",
            "refId": "B"
          }
        ]
      },
      {
        "id": 9,
        "title": "Queue Job Completion Rate",
        "type": "graph",
        "gridPos": { "x": 8, "y": 22, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "rate(queue_jobs_completed_total[5m])",
            "legendFormat": "Completed - {{job_type}}",
            "refId": "A"
          },
          {
            "expr": "rate(queue_jobs_failed_total[5m])",
            "legendFormat": "Failed - {{job_type}}",
            "refId": "B"
          }
        ]
      },
      {
        "id": 10,
        "title": "Cache Hit Rate",
        "type": "graph",
        "gridPos": { "x": 16, "y": 22, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m])) * 100",
            "legendFormat": "{{cache_key}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "percent", "label": "Hit Rate", "max": 100, "min": 0 },
          { "format": "short" }
        ]
      },
      {
        "id": 11,
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "Resident Memory",
            "refId": "A"
          },
          {
            "expr": "nodejs_heap_size_used_bytes",
            "legendFormat": "Heap Used",
            "refId": "B"
          }
        ],
        "yaxes": [
          { "format": "bytes", "label": "Memory" },
          { "format": "short" }
        ]
      },
      {
        "id": 12,
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": { "x": 12, "y": 28, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[5m]) * 100",
            "legendFormat": "CPU Usage",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "percent", "label": "CPU %" },
          { "format": "short" }
        ]
      },
      {
        "id": 13,
        "title": "Alerts Triggered",
        "type": "graph",
        "gridPos": { "x": 0, "y": 34, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "rate(alerts_triggered_total[5m])",
            "legendFormat": "{{alert_type}} - {{priority}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 14,
        "title": "Circuit Breaker Trips",
        "type": "graph",
        "gridPos": { "x": 12, "y": 34, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "rate(circuit_breaker_trips_total[5m])",
            "legendFormat": "{{bridge_id}} - {{reason}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 15,
        "title": "WebSocket Connections",
        "type": "graph",
        "gridPos": { "x": 0, "y": 40, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "websocket_connections_active",
            "legendFormat": "Active Connections",
            "refId": "A"
          }
        ]
      },
      {
        "id": 16,
        "title": "API Key Request Rate by Tier",
        "type": "graph",
        "gridPos": { "x": 8, "y": 40, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "rate(api_key_requests_total[5m])",
            "legendFormat": "{{tier}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 17,
        "title": "Rate Limit Hits",
        "type": "graph",
        "gridPos": { "x": 16, "y": 40, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "rate(api_key_rate_limit_hits_total[5m])",
            "legendFormat": "{{tier}}",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
